#!/usr/bin/env -S uv run --script
#MISE description="Initialize frontmatter on a file"
#USAGE arg "<file>" help="Markdown file to initialize"
#USAGE arg "[fields]" var=#true help="Optional field=value pairs"
# /// script
# dependencies = ["pyyaml"]
# ///

import os
import shlex
import sys

sys.path.insert(0, os.environ["MISE_CONFIG_ROOT"] + "/lib")
from farts import init_frontmatter, resolve_path

path = resolve_path(os.environ["usage_file"])
raw_fields = os.environ.get("usage_fields", "")

fields = {}
if raw_fields:
    for arg in shlex.split(raw_fields):
        if "=" in arg:
            k, _, v = arg.partition("=")
            fields[k] = v

with open(path) as f:
    text = f.read()

result = init_frontmatter(text, fields if fields else None)
with open(path, "w") as f:
    f.write(result)
